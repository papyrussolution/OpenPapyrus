dialog DLG_WORKBOOK [vertical title: "@content" size: (665, 570) minsize: (665, 570) padding: 4 font: "MS Shell Dlg,8"] { // @v12.5.6
	view [horizontal width: bycontainer growfactor: 2.5] {
		view [vertical growfactor: 2 height: bycontainer] {
			input CTL_WORKBOOK_NAME [width: bycontainer height: 21 margin: 4 tabstop label: "@workbook_name"] string[128];
			view [horizontal width: bycontainer height: 40] {
				input CTL_WORKBOOK_CODE [growfactor: 1 height: 21 margin: 4 tabstop label: "@workbook_symb"] string[20];
				input CTL_WORKBOOK_RANK [size: (75, 21) margin: 4 tabstop label: "@workbook_rank"] int32;
				input CTL_WORKBOOK_ID [size: (80, 21) margin: 4 tabstop readonly label: "@id"] int32;
			}
			view [horizontal width: bycontainer growfactor: 1] {
				radiocluster CTL_WORKBOOK_TYPE [vertical title: "@type" growfactor: 2 margin: 4] {
					radiobutton [title: "@workbook_type_site"];
					radiobutton [title: "@workbook_type_page"];
					radiobutton [title: "@workbook_type_css"];
					radiobutton [title: "@workbook_type_media"];
					radiobutton [title: "@workbook_type_folder"];
					radiobutton [title: "@workbook_type_note"];
				}
				view [vertical growfactor: 3 height: bycontainer] {
					checkcluster CTL_WORKBOOK_FLAGS [vertical title: "@flags" width: bycontainer margin: 4] {
						checkbox [title: "@workbook_ppwbf_hidden"];
						checkbox [title: "@workbook_ppwbf_dontshowchildren"];
					}
					framebox [horizontal title: "@datetime" width: bycontainer height: 50 margin: (4, 4, 4, 4) padding: 4 alignitems: center justifycontent: spaceevenly] {
						input CTL_WORKBOOK_DT [size: (90, 21) margin: 4 tabstop fmtf: (dmy)] date supplement datecalbutton(CTLCAL_WORKBOOK_DT);
						input CTL_WORKBOOK_TM [size: (90, 21) margin: 4 tabstop fmtf: (hms)] time supplement timebutton(CTLTM_WORKBOOK_TM);
					}
				}
			}
			input CTL_WORKBOOK_FILE [title: "@content" width: bycontainer height: 21 margin: 4 tabstop] string[128]
				supplement filebrowsebutton(CTLBRW_WORKBOOK_FILE);
			// @unuse button CTL_WORKBOOK_EDIT_FILE [title: "" size: (21, 21)  command: cmOpenTextFile];
			combobox CTLSEL_WORKBOOK_PARENT [tabstop title: "@workbook_parent" width: bycontainer height: 21 margin: 4 cblinesymb: CTL_WORKBOOK_PARENT];
		}
		view [vertical growfactor: 1 height: bycontainer] {
			imageview CTL_WORKBOOK_IMAGE [width: bycontainer growfactor: 1 margin: 4 staticedge];
			view [horizontal width: bycontainer height: 30 justifycontent: end] {
				button STDCTL_IMGADDBUTTON [title: "" tabstop size: (21, 21) margin: 4 command: cmAddImage];
				button STDCTL_IMGDELBUTTON [title: "" tabstop size: (21, 21) margin: 4 command: cmDelImage];
				button STDCTL_IMGPSTBUTTON [title: "" tabstop size: (21, 21) margin: 4 command: cmPasteImage];
			}
		}
	}
	view [horizontal width: bycontainer height: 45] {
		combobox CTLSEL_WORKBOOK_CSS [tabstop growfactor: 1 height: 21 margin: 4 label: "@workbook_css" cblinesymb: CTL_WORKBOOK_CSS ];
		combobox CTLSEL_WORKBOOK_LINK [tabstop growfactor: 1 height: 21 margin: 4 label: "@workbook_link" cblinesymb: CTL_WORKBOOK_LINK ];
		input CTL_WORKBOOK_VER [size: (70, 21) margin: 4 tabstop label: "@workbook_version" ] string[8];
	}
	input CTL_WORKBOOK_KEYWORDS [width: bycontainer height: 21 margin: 4 tabstop label: "@workbook_keywords"] string[128];
	input CTL_WORKBOOK_DESCR [width: bycontainer growfactor: 1 margin: 4 tabstop multiline wantreturn label: "@description"] string[255];
	view [horizontal width: bycontainer height: 28 margin_right: 12] {
		view [horizontal growfactor: 1 height: bycontainer] {
			button STDCTL_TAGSBUTTON [title: "@but_tags" tabstop size: (90, 21) margin: 4 command: cmTags];
		}
		view [horizontal growfactor: 2 height: bycontainer justifycontent: end alignitems: end] {
			button STDCTL_OKBUTTON [title: "@but_ok" tabstop defaultitem size: (75, 21) margin: 4 command: cmOK];
			button STDCTL_CANCELBUTTON [title: "@but_cancel" tabstop size: (75, 21) margin: 4 command: cmCancel];
		}
	}
}

