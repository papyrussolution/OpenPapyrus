dialog DLG_CALC [vertical title: "@calculator" size: (500, 130) minsize: (500, 130) padding: 4 font: "MS Shell Dlg,8" justifycontent: SpaceBetween] {
	input CTL_CALC_INPUT [width: bycontainer height: 21 margin: 4 tabstop] string[255];
	view [horizontal width: bycontainer growfactor: 1] {
		view [vertical growfactor: 2 height: bycontainer] {
			input CTL_CALC_RESULT [width: bycontainer height: 21 margin: 4 tabstop] string[250];
			input CTL_CALC_MEMVIEW [width: bycontainer height: 21 margin: 4 tabstop fmtf: (tricomma notrailz) fmtprec: 8] double;
		}
		view [vertical growfactor: 1 height: bycontainer] {
			view [horizontal width: bycontainer height: 21 margin: 4 alignitems: end justifycontent: SpaceBetween] {
				button CTL_CALC_EQ [title: "=" tabstop defaultitem size: (75, 21) margin: (4, 0, 4, 0) command: cmCalcEq];
				button CTL_CALC_MEM [title: "&M" tabstop size: (30, 21) margin: (4, 0, 4, 0) command: cmCalcMem];
				button CTL_CALC_PLUSMEM [title: "&+M" tabstop size: (30, 21) margin: (4, 0, 4, 0) command: cmCalcPlusMem];
			}
			view [horizontal width: bycontainer height: 21 margin: 4 alignitems: end justifycontent: SpaceBetween] {
				button CTL_CALC_MINUSMEM [title: "&-M" tabstop size: (30, 21) margin: (4, 0, 4, 0) command: cmCalcMinusMem];
				button STDCTL_CANCELBUTTON [title: "@but_cancel" tabstop size: (75, 21) margin: (4, 0, 4, 0) command: cmCancel];
			}
		}
	}
}

