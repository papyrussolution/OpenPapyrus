	}
	statictext CTL_BILL_ST_LINKBILL [width: bycontainer height: 16 staticedge];
	view [horizontal] {
		statictext CTL_BILL_ST_SCARD [size: (165, 24)  staticedge];
		statictext CTL_BILL_STATUS [title: "Status" size: (135, 24)  staticedge];
	}
