cinclude "../../include/tvdefs.h"
cinclude "../../include/ppdefs.h"
/*
	Параметры выравнивания:
		justifycontent - Выравнивание внутренних элементов вдоль основной оси
		aligncontent - Выравнивание внутренних элементов по кросс-оси
		alignitems
		alignself

	Значения параметров выравнивания:
		auto
		stretch
		center
		start
		end
		spacebetween
		spacearound
		spaceevenly
*/
/*
	supplement kind ( symbol )
	supplement kind ( symbol cmd_symbol )
	supplement kind ( symbol "text" )
	supplement kind ( symbol cmd_symbol "text" )

	supplement_kind:
		datecalbutton
		daterangecalbutton
		listbutton
		calcbutton
		timebutton
		asterbutton
		filebrowsebutton
		filtbutton
		ellipsisbutton
		numberstepper
*/

dialog DLG_GSTRUCTREE [vertical title: "@ttl_goodsstructree" size: (540, 540) minsize: (300, 300) font: "MS Shell Dlg,8"] {
	treelistbox CTL_GSTRUCTREE_LIST [tabstop width: bycontainer growfactor: 1];
	view [horizontal width: bycontainer height: 30 justifycontent: end alignitems: end margin_right: 12] {
		button STDCTL_CANCELBUTTON [title: "@but_close" tabstop size: (75, 21) margin: 4 command: cmClose];
	}
}

dialog DLG_LBXSEL [vertical title: "@{selection} %s" size: (530, 400) minsize: (530, 200) font: "MS Shell Dlg,8"] {
	listbox CTL_LBXSEL_LIST [tabstop width: bycontainer growfactor: 1];
	view [horizontal width: bycontainer height: 28] {
		view [horizontal growfactor: 4 height: bycontainer(100) gravity: left justifycontent: start] {
			button STDCTL_EDITBUTTON [title: "@but_edit" tabstop defaultitem size: (90, 21) margin: 4 command: cmaEdit];
			button STDCTL_INSBUTTON [title: "@but_add" tabstop size: (90, 21) margin: 4 command: cmaInsert];
			button STDCTL_DELBUTTON [title: "@but_delete" tabstop size: (90, 21) margin: 4 command: cmaDelete];
			button STDCTL_UPBUTTON [title: "" tabstop size: (23, 21) margin: 4 command: cmUp];
			button STDCTL_DOWNBUTTON [title: "" tabstop size: (23, 21) margin: 4 command: cmDown];
		}
		view [horizontal growfactor: 2 height: bycontainer(100) margin_right: 12 gravity: right justifycontent: end] {
			button STDCTL_OKBUTTON [title: "@but_ok" tabstop size: (75, 21) margin: 4 command: cmOK];
			button STDCTL_CANCELBUTTON [title: "@but_cancel" tabstop size: (75, 21) margin: 4 command: cmCancel];
		}
	}
}

